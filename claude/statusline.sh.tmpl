#!/usr/bin/env bash
# Minimal Claude Code statusline. Reads the JSON payload on stdin.
# Docs: https://docs.claude.com/en/docs/claude-code/statusline
set -eu
payload="$(cat)"
model=$(printf '%s' "$payload" | jq -r '.model.display_name // "claude"' 2>/dev/null || echo claude)
cwd=$(printf '%s' "$payload"   | jq -r '.workspace.current_dir // .cwd // ""' 2>/dev/null || pwd)
short_cwd="${cwd/#$HOME/~}"
branch=""
if command -v git >/dev/null 2>&1 && [ -n "$cwd" ] && [ -d "$cwd" ]; then
  branch=$(git -C "$cwd" symbolic-ref --short HEAD 2>/dev/null || true)
  [ -n "$branch" ] && branch=" ⎇ $branch"
fi
printf '\033[2m%s\033[0m  \033[36m%s\033[0m\033[33m%s\033[0m' "$model" "$short_cwd" "$branch"
