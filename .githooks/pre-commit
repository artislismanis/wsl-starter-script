#!/usr/bin/env bash
# pre-commit — block commits that would land broken shell or CRLF endings.
# Enable with:  git config core.hooksPath .githooks
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=ACMR)
[ "${#STAGED[@]}" -gt 0 ] || exit 0

SHELL_FILES=()
NONSHELL_TEXT=()
for f in "${STAGED[@]}"; do
  [ -f "$f" ] || continue
  case "$f" in
    *.sh|.githooks/pre-commit)
      SHELL_FILES+=("$f") ;;
    *.md|*.json|*.toml|*.yml|*.yaml|*.tmpl|*.conf|.gitattributes|.editorconfig)
      NONSHELL_TEXT+=("$f") ;;
  esac
done

fail=0

# CRLF on shell files is caught by lint.sh; here we only need to cover the
# non-shell text files (.md/.json/.tmpl/...) it doesn't see.
for f in "${NONSHELL_TEXT[@]}"; do
  if LC_ALL=C grep -q $'\r' "$f"; then
    echo "pre-commit: CRLF endings in $f — fix with: dos2unix $f" >&2
    fail=1
  fi
done

if [ "${#SHELL_FILES[@]}" -gt 0 ]; then
  ./lint.sh "${SHELL_FILES[@]}" || fail=1
fi

if [ "$fail" != "0" ]; then
  echo "pre-commit: blocking commit. Use 'git commit --no-verify' to override." >&2
  exit 1
fi
